PORT=5000
# Comma-separated — must include your Netlify URL (no trailing slash)
# Example: http://localhost:5173,https://agriconnectaii.netlify.app
CLIENT_ORIGIN=http://localhost:5173
# Optional extra frontend URL (also allowed)
# NETLIFY_URL=https://agriconnectaii.netlify.app
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/agriconnect
ACCESS_TOKEN_SECRET=replace_with_secure_secret
REFRESH_TOKEN_SECRET=replace_with_secure_secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@agriconnect.ai
