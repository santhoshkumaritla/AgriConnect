# ========== PRODUCTION — set in Render Dashboard (Environment) ==========
# Do not put real secrets in this file. Copy names + your values into Render only.

PORT=5000

# Netlify frontend + local testing (comma-separated, no trailing slash)
CLIENT_ORIGIN=http://localhost:5173,https://agriconnectaii.netlify.app

# MongoDB Atlas — production cluster connection string
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/agriconnect?retryWrites=true&w=majority

# JWT — generate NEW secrets for production (never reuse local secrets)
ACCESS_TOKEN_SECRET=replace_with_long_random_string
REFRESH_TOKEN_SECRET=replace_with_another_long_random_string
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# Gmail SMTP (optional — set EMAIL_ENABLED=false to disable)
EMAIL_ENABLED=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=yourname@gmail.com
SMTP_PASS=your_16_char_gmail_app_password
SMTP_FROM=yourname@gmail.com

# Optional: extra frontend URL
# NETLIFY_URL=https://agriconnectaii.netlify.app
